{
  "name": "decomk-selftest-devpod-local",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
    "containerEnv": {
      "DECOMK_HOME": "/tmp/decomk-selftest/home",
      "DECOMK_LOG_DIR": "/tmp/decomk-selftest/log",
      "DECOMK_TOOL_URI": "__DECOMK_TOOL_URI__",
      "DECOMK_CONF_URI": "__DECOMK_CONF_URI__",
      "DECOMK_FAIL_NOBOOT": "false"
    },
  "remoteUser": "dev",
  "containerUser": "dev",
  "updateRemoteUserUID": false,
  "updateContentCommand": "bash .devcontainer/decomk-stage0.sh updateContent",
  "postCreateCommand": "bash .devcontainer/decomk-stage0.sh postCreate"
}
