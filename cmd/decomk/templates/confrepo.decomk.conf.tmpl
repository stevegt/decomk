# This file is the policy map for decomk.
# A "context" is a key on the left side of ":".
# A context expands into a list of tokens on the right side.
#
# A token can be:
# - another context key (macro-style composition),
# - or a tuple (`NAME=value`) passed to make as a variable.
#
# Bare make target names are intentionally not allowed on the RHS. Put target
# lists inside tuple values (for example `updateContent='all'`).
#
# Start simple:
# - `DEFAULT` is the baseline policy shared by all repos.
# - Add one context key per repo (`owner/repo`) as needed.

DEFAULT:
  updateContent='all'
  postCreate='all'
  HELLO_TEXT='Hello from DEFAULT context'
  DEVCONTAINER_GUI=0

# Example repo-specific override.
# Replace `owner/repo` with your real repository key.
owner/repo: DEFAULT
  HELLO_TEXT='Hello from owner/repo context'
  DEVCONTAINER_GUI=$

# Tuple passthrough note:
# `NAME=$` means "use incoming environment value for NAME when set".
# In this example, if `DEVCONTAINER_GUI` exists in the runtime environment,
# decomk uses that value; otherwise it falls back to DEFAULT's `DEVCONTAINER_GUI=0`.
