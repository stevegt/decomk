// This file is a producer-workspace starter for the shared conf repo.
// The build stanza below is intended for genesis bootstrap only.
// After your genesis image is stable:
//   1) remove the `build` stanza,
//   2) add an `image` stanza (for example `ghcr.io/<org>/<repo>:stable`),
//   3) remove the active need for `.devcontainer/Dockerfile`.
{
  "name": {{json .Name}},
  "build": {
    "dockerfile": {{json .BuildDockerfile}},
    "context": {{json .BuildContext}}
  },
    "containerEnv": {
      "DECOMK_HOME": {{json .Home}},
      "DECOMK_LOG_DIR": {{json .LogDir}},
      "DECOMK_TOOL_URI": {{json .ToolURI}},
      "DECOMK_CONF_URI": {{json .ConfURI}},
      "DECOMK_FAIL_NOBOOT": {{json .FailNoBoot}},
      "DECOMK_REMOTE_USER": {{json .RemoteIdentityUser}},
      "DECOMK_REMOTE_UID": {{json .RemoteIdentityUID}}
    },
{{- if .RemoteUser }}
  "remoteUser": {{json .RemoteUser}},
{{- end }}
{{- if .ContainerUser }}
  "containerUser": {{json .ContainerUser}},
{{- end }}
{{- if ne .UpdateRemoteUserUID nil }}
  "updateRemoteUserUID": {{json .UpdateRemoteUserUID}},
{{- end }}
  "updateContentCommand": {{json .UpdateContentCommand}},
  "postCreateCommand": {{json .PostCreateCommand}}
}
